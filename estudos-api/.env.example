# PostgreSQL connection used by the `postgres` Spring profile.
# These are read as environment variables (Spring resolves ${DB_URL:default} in
# application-postgres.yml). Copy this file to `.env` and export the values, or
# pass them in your shell, before running:
#   mvn spring-boot:run -Dspring-boot.run.profiles=postgres
#
# The in-memory H2 profile (default) needs none of these.

DB_URL=jdbc:postgresql://localhost:5432/estudos
DB_USERNAME=estudos
DB_PASSWORD=estudos
