# Copy to .env on the VM (cd ~/atlas). Never commit the real .env.

# Postgres password — generate with: openssl rand -base64 24
DB_PASSWORD=change-me

# Public domain for HTTPS. With no domain, use sslip.io: atlas.<PUBLIC_IP>.sslip.io
DOMAIN=atlas.example.com

# Container image. Override the tag for rollbacks, e.g. :<git-sha>
APP_IMAGE=ghcr.io/whoisleonardo/atlas-study:latest
